    <string name="sensitivity_quiet_bedroom_description">更愿意捕捉轻声梦话，但也更容易被细微环境噪音触发。</string>
    <string name="sensitivity_normal_room_label">普通房间</string>
    <string name="sensitivity_normal_room_description">适合大多数卧室和常见睡眠环境，建议作为默认值。</string>
    <string name="sensitivity_noisy_room_label">嘈杂房间</string>
    <string name="sensitivity_noisy_room_description">更保守，能减少风扇、空调等持续背景噪音造成的误触发。</string>

