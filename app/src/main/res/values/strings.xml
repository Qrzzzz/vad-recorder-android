    <string name="dialog_delete_title">Delete this clip?</string>
    <string name="dialog_delete_body">This will remove the file permanently. Use it to clear false triggers or clips you do not want to keep.</string>
    <string name="action_delete">Delete</string>
    <string name="action_cancel">Cancel</string>

    <string name="home_title">Dream Talk Recorder</string>
    <string name="home_subtitle">The app saves clips when voice is detected. Stopping the listener saves the current clip immediately.</string>
    <string name="tip_recorder_error_title">Recorder error</string>
    <string name="section_last_night_title">Last night summary</string>
    <string name="section_last_night_subtitle">See how many clips were captured, how long they were, and how late the last one happened.</string>
    <string name="section_night_recordings_title">Night recordings</string>
    <string name="section_night_recordings_subtitle">You can play clips right away and delete obvious false triggers.</string>
    <string name="tip_playback_failed_title">Playback failed</string>
    <string name="playback_failed_fallback">Playback failed. Please try again.</string>
    <string name="empty_clips_message">No clips yet. Start listening, place the phone near the bed, and the app will save clips when it hears voice.</string>

    <string name="settings_title">Settings</string>
    <string name="settings_subtitle">Language, auto-stop, and sensitivity all live here. Auto-stop updates the current listening session immediately.</string>
    <string name="language_title">Language</string>
    <string name="language_subtitle">Keep the system language, or force English or Simplified Chinese for the app.</string>
    <string name="language_system">Follow system</string>
    <string name="language_english">English</string>
    <string name="language_chinese_simplified">简体中文</string>
    <string name="language_effect_running">The change applies immediately and refreshes the active listening notification.</string>
    <string name="language_effect_stopped">The change applies immediately the next time this screen redraws.</string>
    <string name="tip_microphone_permission_title">Microphone permission is missing</string>
    <string name="tip_microphone_permission_body_settings">The recorder cannot listen without microphone permission. Open system settings and re-enable it for this app.</string>
    <string name="tip_microphone_permission_body_request">Grant microphone permission when you tap Start listening so the recorder can actually detect voice.</string>
    <string name="action_open_settings">Open settings</string>
    <string name="tip_notifications_title">Notifications are off</string>
    <string name="tip_notifications_body">The foreground service may still run, but it is harder to confirm that listening is still active. Turning notifications on makes the state easier to verify.</string>
    <string name="action_notification_settings">Notification settings</string>
    <string name="tip_battery_title">Battery optimization may interrupt listening</string>
    <string name="tip_battery_body">Some phones are aggressive about background limits after the screen is off. If you expected clips overnight and got none, check battery optimization and background restrictions first.</string>
    <string name="action_battery_settings">Battery settings</string>

    <string name="auto_stop_title">Auto-stop listening</string>
    <string name="auto_stop_body">Choose how many hours a listening session may run before the app stops it automatically.</string>
    <string name="auto_stop_on">Auto-stop is on</string>
    <string name="auto_stop_off">Auto-stop is off</string>
    <string name="auto_stop_changes_immediate">Changes apply to the current listening session immediately.</string>
    <string name="auto_stop_changes_next_session">Changes apply the next time you start listening.</string>
    <string name="auto_stop_range">Range: 1 to 12 hours.</string>

    <string name="sensitivity_title">Sensitivity preset</string>
    <string name="sensitivity_body">Pick the room condition instead of tuning raw thresholds. The preset is locked while listening is active.</string>
    <string name="sensitivity_quiet_bedroom_label">Quiet bedroom</string>
    <string name="sensitivity_quiet_bedroom_description">More willing to capture soft dream talk, but also easier to trigger on subtle room noise.</string>
    <string name="sensitivity_normal_room_label">Normal room</string>
    <string name="sensitivity_normal_room_description">Recommended default for most bedrooms and typical sleeping environments.</string>
    <string name="sensitivity_noisy_room_label">Noisy room</string>
    <string name="sensitivity_noisy_room_description">More conservative so fans, AC noise, and other steady background sounds trigger less often.</string>

    <string name="night_summary_empty_title">No clips to summarize yet</string>
    <string name="night_summary_empty_body">Once the app captures real clips, this section will summarize the latest night automatically.</string>

